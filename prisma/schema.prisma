// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model StudyLevel {
  id    Int     @id @default(autoincrement())
  name  String
  slug  String?
  order Int     @default(0)
  units Unit[]

  @@unique([slug])
  @@map("grades")
}

model Unit {
  id      Int        @id @default(autoincrement())
  name    String
  order   Int        @default(0)
  grade   StudyLevel @relation(fields: [gradeId], references: [id], onDelete: Cascade)
  gradeId Int
  lessons Lesson[]

  @@map("units")
}

model Lesson {
  id       Int     @id @default(autoincrement())
  name     String
  order    Int     @default(0)
  sections String? @default("[]")
  unit     Unit    @relation(fields: [unitId], references: [id], onDelete: Cascade)
  unitId   Int
  words    Word[]

  @@map("lessons")
}

model Word {
  id       Int    @id @default(autoincrement())
  en       String
  ar       String
  part     String
  category String // "key" or "additional"
  order    Int    @default(0)
  lesson   Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  lessonId Int

  @@map("words")
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  name      String?
  password  String // Hashed password
  role      String    @default("teacher") // "admin" or "teacher"
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  lastLogin DateTime?

  @@map("users")
}
