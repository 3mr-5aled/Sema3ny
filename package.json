{
  "name": "entqha",
  "version": "1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build --turbopack",
    "start": "next start",
    "postinstall": "prisma generate",
    "lint": "eslint",
    "db:seed": "npx tsx prisma/seed.ts",
    "db:seed:prod": "npx tsx prisma/seed-production.ts",
    "db:migrate": "prisma migrate dev",
